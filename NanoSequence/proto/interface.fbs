// Engine <==> ModelRunner lean communication protocol
// Only transmits fields actually needed by the runner.

namespace nanodeploy.fbs;

table IntListI {
  values: [int];
}

// ========== Run Protocol ==========

// Vision slot reference passed to the model runner during prefill.
// The runner uses this to RDMA-fetch vision embeddings from the encoder.
table VisionSlotRef {
  encoder_engine_id: string;  // Encoder engine that owns the embedding
  slot_idx: int = -1;         // Slot index in encoder's EmbeddingPool
  num_tokens: int;            // Number of vision tokens
  hidden_size: int;           // Hidden dimension per token
  max_tokens_per_slot: int;   // Encoder pool slot stride (max tokens per slot)
}

table SequenceInput {
  master_group_id: int;
  num_tokens: int;
  num_cached_tokens: int;            // prefill only
  num_prompt_tokens: int;            // prefill only: original full prompt length (for chunk detection)
  last_token: int;                   // decode only
  token_ids: [int];                  // prefill only (uncached portion)
  group_block_table: [IntListI];     // block tables per group
  num_dispatched_tokens: [int];      // context lengths per group
  state_slot: int = -1;              // GDN state slot
  temperature: double = 1.0;         // sampling temperature
  vision_slots: [VisionSlotRef];     // vision embedding refs (prefill only, EP mode)
}

table RunBatchInput {
  sequences: [SequenceInput];
  is_prefill: bool;
}

// ========== Migrate Protocol ==========

struct BlockLocationPair {
  group_id: int;
  block_idx: int;
}

table MigrateSequenceInput {
  seq_id: uint64;                              // for logging
  // MIGRATE slot fields
  migrate_engine_id: string;
  migrate_num_kvcache_blocks: int;
  migrate_group_size: int;
  migrate_dp_idx: int;
  migrate_block_location: [BlockLocationPair];
  migrate_state_slot: int = -1;
  // ACTIVE slot fields
  active_block_location: [BlockLocationPair];
  active_state_slot: int = -1;
}

table MigrateBatchInput {
  sequences: [MigrateSequenceInput];
}
