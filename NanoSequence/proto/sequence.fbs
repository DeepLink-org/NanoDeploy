namespace nanodeploy.fbs;

enum SequenceStatus : byte {
  WAITING = 0,
  RUNNING = 1,
  FINISHED = 2,
  TO_BE_MIGRATED = 3,
  PREFILLING = 4,
}

struct BlockLocation {
  first: int;
  second: int;
}

table IntList {
  values: [int];
}

table BlockContext {
  engine_id: string;
  dp_idx: int;
  master_group_id: int;
  group_size: int;
  attention_dp: int;
  num_kvcache_blocks: int;
  state_slot: int = -1;
  block_location: [BlockLocation];
  num_dispatched_tokens: [int];
  group_block_table: [IntList];
  endpoints: [string];
}

table SamplingParams {
  temperature: double = 1.0;
  max_tokens: int = 256;
  ignore_eos: bool;
}

// Vision embedding slot reference on the encoder side.
// Each slot occupies a contiguous region in the encoder's EmbeddingPool buffer.
table VisionSlot {
  encoder_engine_id: string;  // Encoder engine that owns this slot
  slot_idx: int = -1;         // Slot index in the encoder's EmbeddingPool
  num_tokens: int;            // Number of merged vision tokens in this slot
  hidden_size: int;           // Hidden dimension of each token embedding
  max_tokens_per_slot: int;   // Encoder pool slot stride (max tokens per slot)
}

table Sequence {
  seq_id: uint64;
  status: SequenceStatus;
  sampling_params: SamplingParams;
  last_token: int;
  num_tokens: int;
  num_prompt_tokens: int;
  num_checkpointed_tokens: int;
  num_cached_tokens: int;
  token_ids: [int];
  slots: [BlockContext];  // Direct vector - size enforced in C++ code
  vision_slots: [VisionSlot];  // Vision embedding references (EP separated mode)
}

table SequenceList {
  sequences: [Sequence];
}

table StepOut {
  seq_id: uint64;
  token_id: uint;  // Deprecated: kept for backward compatibility
  token_ids: [uint];  // New field: supports multiple tokens
  status: SequenceStatus;
}

table FreeSequences {
  seq_ids: [uint64];
  source_engine_id: string;
}

// P2P message from Prefill to Encoder to release vision embedding slots.
table FreeVisionSlots {
  encoder_engine_id: string;   // Target encoder engine
  slot_indices: [int];         // Slot indices to free
  source_engine_id: string;    // Prefill engine that consumed the embeddings
}

root_type SequenceList;
